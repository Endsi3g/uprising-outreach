# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://outreach:outreach@localhost/outreach
DATABASE_URL_TEST=postgresql+asyncpg://outreach:outreach@localhost/outreach_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-url-safe-fernet-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

