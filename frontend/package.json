{
  "name": "outreach-frontend",
  "version": "0.1.0",
  "description": "ProspectOS - Système d'Intelligence Commerciale",
  "author": "Uprising Studio",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/",
    "clean": "powershell -Command \"Remove-Item -LiteralPath 'out', '.next', 'dist' -Recurse -Force -ErrorAction SilentlyContinue\"",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "next build && electron-builder",
    "build:electron:full": "npm run clean && $env:CSC_LINK=$null; $env:WIN_CSC_LINK=$null; npm run build:electron"
  },
  "build": {
    "appId": "com.uprising.prospectos",
    "productName": "ProspectOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.43.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "jsdom": "^25.0.0",
    "postcss": "^8",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
